{
  "name": "@itkujo/sms-edge",
  "version": "0.1.2",
  "description": "HTTP bridge from Logto's connector-http-sms to our self-hosted SMSGate, using @itkujo/sms-core.",
  "type": "module",
  "main": "./dist/index.js",
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess 'node --env-file=.env --watch dist/index.js'",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured yet'"
  },
  "dependencies": {
    "@itkujo/sms-core": "github:itkujo/sms-core#v0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/itkujo/sms-edge.git"
  },
  "license": "UNLICENSED",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
